# =============================================================================
# KrewsAgent — copy to .env.local and fill in (NEVER commit .env.local)
# =============================================================================

# --- Required: Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# --- Required: auth sessions ---
# Generate: openssl rand -base64 32
AUTH_SECRET=replace_with_openssl_rand_base64_32_output

# --- App URL (local dev + OAuth redirects) ---
# Production: set to https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- TARS / Tetrate (optional — DEMO_MODE fallback works without key) ---
TARS_API_KEY=your_tars_api_key_here
TARS_BASE_URL=https://api.router.tetrate.ai/v1

# --- Demo mode ---
DEMO_MODE=true
# Stable demo user — printed by `npm run seed`
DEMO_USER_ID=c0ffee00-0000-4000-8000-000000000001

# --- Gmail OAuth (Ops crew: read inbox + spam/tabs; draft or send on approve) ---
# Google Cloud Console → APIs & Services → Credentials → OAuth client
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/gmail/callback

# --- GitHub OAuth (Support crew: read issues + post comment on approve) ---
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_REDIRECT_URI=http://localhost:3000/api/integrations/github/callback

# --- GitHub defaults (until user picks a repo on /connect) ---
GITHUB_OWNER=demoprojectz56t-max
GITHUB_REPO=concept-to-code-dash

# Optional PAT fallback if user has not connected GitHub OAuth
GITHUB_TOKEN=your_github_pat_here

# --- Password reset emails (optional in dev — reset link logs to console) ---
# Resend: https://resend.com
RESEND_API_KEY=
AUTH_EMAIL_FROM=KrewsAgent <onboarding@resend.dev>

# --- Optional: `npm run setup` schema apply ---
# Supabase → Settings → Database → Connection string → Session pooler URI
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
# SUPABASE_DB_PASSWORD=
